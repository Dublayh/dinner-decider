{
  "expo": {
    "name": "Let's Eat!",
    "slug": "dinner-decider",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#C17A3C"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#C17A3C"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.dublayh.dinnerdecider"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro",
      "output": "static",
      "name": "Let's Eat!",
      "shortName": "Let's Eat",
      "description": "Spin the wheel, decide dinner.",
      "themeColor": "#C17A3C",
      "backgroundColor": "#FAF7F2",
      "preferRelatedApplications": false
    },
    "plugins": [
      "expo-router"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "c81604a6-f1a6-4ec2-a450-88314e2b8f50"
      }
    },
    "owner": "dublayh"
  }
}
